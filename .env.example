NODE_ENV=development
PORT=5000

# MongoDB connection (Atlas or local) — special characters in the password
# must be percent-encoded (e.g. @ -> %40, # -> %23, ( -> %28, ) -> %29, ! -> %21)
MONGODB_URI=mongodb+srv://your_user:your_encoded_password@cluster0.xxxxx.mongodb.net/eecmi?retryWrites=true&w=majority&appName=Cluster0

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password
CLIENT_URL=http://localhost:3000

# Clerk authentication
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
# Comma-separated emails auto-promoted to super_admin on first sign-in
SUPER_ADMIN_EMAILS=admin@eecmi.org
